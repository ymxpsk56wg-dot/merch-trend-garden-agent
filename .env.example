TREND_LIMIT=12
TREND_GEO=US

# Optional marketplace/research connectors. The app lists these in /api/sources
# and can be extended to promote them to active review sources when keys are set.
EBAY_ACCESS_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US

# Etsy v3 app-level public marketplace search. ETSY_API_KEY should be the
# x-api-key value Etsy expects; alternatively set ETSY_KEYSTRING and
# ETSY_SHARED_SECRET and the server will combine them.
ETSY_API_KEY=
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=

YOUTUBE_API_KEY=

# Figma REST is optional for read/export checks. The app also serves a plugin
# at /figma-plugin/manifest.json that creates boards inside Figma.
APP_PUBLIC_URL=https://merch-trend-garden-agent-production.up.railway.app
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
